{
  "name": "agent-ready-site-template",
  "version": "1.0.0",
  "private": true,
  "description": "A fast, accessible personal website template with first-class machine-readable publishing.",
  "scripts": {
    "predev": "npm run generate:machine",
    "dev": "next dev -H 127.0.0.1",
    "prebuild": "npm run generate:machine",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "pretest:e2e": "npm run generate:machine && npm run build",
    "test:e2e": "playwright test",
    "generate:machine": "tsx scripts/generate-machine-content.ts",
    "check:machine": "tsx scripts/generate-machine-content.ts --check",
    "check": "npm run check:machine && npm run lint && npm run typecheck && npm run test:unit && npm run build"
  },
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10 <12"
  },
  "dependencies": {
    "gray-matter": "4.0.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "packageManager": "npm@11.12.1"
}
